{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Chrome (Supabase)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "args": [
        "--dart-define-from-file=.env/dev.json",
        "--web-browser-flag=--disable-extensions",
        "--web-browser-flag=--user-data-dir=%TEMP%\\flutter_chrome_profile"
      ]
    }
  ]
}